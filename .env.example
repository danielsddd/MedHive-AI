# =====================================================================
# TAU 3346 — ENVIRONMENT TEMPLATE  (copy to .env, never commit .env)
# =====================================================================
# HOW TO USE
#   1. cp .env.example .env
#   2. Leave it as-is to run fully OFFLINE (no keys, no internet) — the app,
#      tests, and demo all boot using deterministic stub providers.
#   3. To go live, paste a real key next to the matching variable and set the
#      relevant *_MODE to "live" (or leave it "auto" — auto goes live the moment
#      a key is present). NO CODE CHANGES are ever required to swap a provider.
# ---------------------------------------------------------------------
# PROVIDER-SWAP CHEAT SHEET (change a string + a key, nothing else):
#   Extraction LLM : EXTRACTION_MODEL   + the matching *_API_KEY below
#   Explanation LLM: EXPLANATION_MODEL  + the matching *_API_KEY below
#   Embeddings     : EMBEDDING_MODEL_ACTIVE = local | api
# =====================================================================

# ---------- RUN MODES (the master switches) ----------
# auto  = go live if a key is present, else fall back to offline stub
# live  = force real providers (fails loudly if keys are missing)
# offline / dev = force stubs (no network, no keys needed)
LLM_MODE=auto
EMBEDDING_MODE=auto
AUTH_MODE=auto

# ---------- VECTOR DIMENSION (LOCKED — never change) ----------
VECTOR_DIMENSIONS=768

# ---------- DATABASE (local pgvector container) ----------
POSTGRES_DB=medcollab
POSTGRES_USER=app
POSTGRES_PASSWORD=change_me_local_only
# SQLAlchemy/asyncpg URL used by FastAPI + Alembic:
DATABASE_URL=postgresql+asyncpg://app:change_me_local_only@postgres:5432/medcollab

# ---------- REDIS (self-hosted container — ARQ queue + rate limits) ----------
REDIS_URL=redis://redis:6379/0

# ---------- LLM MODEL STRINGS (config only — never hard-coded in code) ----------
# LIVE as of Jun 2026. DEAD strings (never use): gemini-2.0-flash,
# gemini-2.0-flash-lite, text-embedding-004.
EXTRACTION_MODEL=gemini/gemini-2.5-flash
EXTRACTION_FALLBACK=groq/llama-3.3-70b-versatile
EXPLANATION_MODEL=groq/llama-3.3-70b-versatile
EXPLANATION_FALLBACK=groq/llama-3.1-8b-instant

# ---------- EMBEDDING MODELS ----------
EMBEDDING_MODEL_LOCAL=all-mpnet-base-v2
EMBEDDING_MODEL_API=gemini-embedding-001
EMBEDDING_MODEL_ACTIVE=local
ACTIVE_EMBEDDING_COLUMN=embedding

# ---------- PROVIDER API KEYS (paste a key to go live; blank = stub) ----------
# LiteLLM reads these by their standard names — that is the whole swap mechanism.
GEMINI_API_KEY=
GROQ_API_KEY=
# Optional tested fallbacks — wire ONE, then point a *_MODEL/*_FALLBACK at it:
CEREBRAS_API_KEY=
GITHUB_MODELS_TOKEN=

# ---------- SUPABASE AUTH (JWT issuer only; app DB is the local Postgres) ----------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# ^ SERVICE_ROLE_KEY is BACKEND-ONLY. Never expose to the frontend. Never log it.

# ---------- RATE CAPS (keep <= 50% of each provider's real limit) ----------
INGEST_PER_HOUR=3
EXPLAIN_PER_MIN=10
MATCH_PER_MIN=30

# ---------- PARSING GUARDS ----------
CV_MIN_CHARS=200
CV_MAX_TOKENS=12000
MAX_FILE_MB=20

# ---------- MISC ----------
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000
