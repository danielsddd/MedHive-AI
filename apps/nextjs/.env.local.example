# Frontend-only PUBLIC env. Copy to .env.local. NEVER put the service-role key here.
# Only NEXT_PUBLIC_* values are sent to the browser, so only public keys belong here.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Base URL of the FastAPI backend (the ONE backend surface). All business calls go here.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
